# ── LLM API Keys ──────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter (structured LLM nodes and RAG embedding)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=A3 Study Agent
OPENROUTER_DEEPSEEK_MODEL=deepseek/deepseek-v4-flash
# SiliconFlow (optional fallback / legacy provider)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ── RAG ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=chroma_store/
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY_ENV=OPENROUTER_API_KEY
EMBEDDING_DOCUMENT_INPUT_TYPE=passage
EMBEDDING_QUERY_INPUT_TYPE=query
EMBEDDING_TIMEOUT=60
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_BASE_URL=https://api.siliconflow.cn/v1
RERANKER_API_KEY_ENV=SILICONFLOW_API_KEY
INDEX_ADD_BATCH_SIZE=64
INDEX_MAX_RETRIES=3

# ── Fallback LLM ──────────────────────────────────────────
FALLBACK_MODEL=Qwen/Qwen2.5-7B-Instruct
FALLBACK_API_KEY=your_siliconflow_api_key_here
FALLBACK_BASE_URL=https://api.siliconflow.cn/v1

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_PASSWORD=tutor_dev

# LangGraph checkpointer
CHECKPOINTER_ENABLED=true
CHECKPOINTER_TYPE=memory

# ── CORS & Frontend ───────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Web Search
TAVILY_API_KEY=tvly-YOUR_API_KEY
WEB_SEARCH_PROVIDER=tavily

# ── Observability ─────────────────────────────────────────
OTEL_SERVICE_NAME=a3-study-agent
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACING_ENABLED=true
OTEL_SQLITE_FALLBACK_PATH=logs/traces.sqlite3

# ── Temporary A3_TRACE development diagnostics ───────────────────
# Master switch for all structured development trace logs
LOG_A3_TRACE=false

# Fine-grained trace switches
LOG_SUPERVISOR_RESULT=false
LOG_QUERY_REWRITE_RESULT=false
LOG_RETRIEVAL_PLAN=false
LOG_RAG_RESULT=false
LOG_CONTEXT_ASSEMBLY=false
LOG_WEB_SEARCH_RESULT=false
LOG_GENERATION_SUMMARY=false
LOG_PLANNING_INTEL=false
LOG_RETRY_TRACE=false
LOG_STRUCTURED_LLM_OUTPUT=false
