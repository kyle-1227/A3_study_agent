# Copy this file to .env and replace every required placeholder before startup.
# Never commit .env or paste secret values into logs and reports.

# LLM provider used by the served graph
DEEPSEEK_API_KEY=replace_with_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Legacy rollback and memory-embedding provider. Keep configured until the
# Parent-Child RAG canary has passed and the legacy path is explicitly retired.
OPENROUTER_API_KEY=replace_with_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=A3 Study Agent

# Parent-Child RAG provider secrets. The strict runtime configuration stores
# only these environment-variable names, never the secret values.
RAG_EMBEDDING_API_KEY=replace_with_rag_embedding_api_key
RAG_RERANKER_API_KEY=replace_with_rag_reranker_api_key
EMBEDDING_API_KEY_ENV=RAG_EMBEDDING_API_KEY
RERANKER_API_KEY_ENV=RAG_RERANKER_API_KEY

# Docker bind mounts: the backend reads only the Parent--Child primary below
# this index root and never mounts a legacy chroma_store.
COURSE_DATA_HOST_PATH=./data
PARENT_CHILD_INDEX_HOST_PATH=./indexes/parent_child


# PostgreSQL. Docker Compose constructs the container DB_URI from this required
# password. The explicit DB_URI below is for local non-Compose startup.
POSTGRES_PASSWORD=replace_with_strong_postgres_password
CHECKPOINTER_ENABLED=true
CHECKPOINTER_TYPE=postgres
DB_URI=postgresql://a3_user:replace_with_strong_postgres_password@localhost:5432/a3_study_agent

# Frontend and CORS
ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Web search
TAVILY_API_KEY=replace_with_tavily_api_key
WEB_SEARCH_PROVIDER=tavily

# Observability is off in the base deployment. To enable it, start Compose with
# --profile observability and change the endpoint to http://jaeger:4317 inside
# Docker or http://localhost:4317 for a host-started backend.
OTEL_SERVICE_NAME=a3-study-agent
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACING_ENABLED=false
OTEL_SQLITE_FALLBACK_PATH=logs/traces.sqlite3

# Production uses the strict context policy.
CONTEXT_POLICY_MODE=strict

# Development diagnostics. Keep disabled in production unless investigating a
# bounded issue; trace bodies remain security-sensitive.
LOG_A3_TRACE=false
LOG_SUPERVISOR_RESULT=false
LOG_QUERY_REWRITE_RESULT=false
LOG_RETRIEVAL_PLAN=false
LOG_RAG_RESULT=false
LOG_CONTEXT_ASSEMBLY=false
LOG_WEB_SEARCH_RESULT=false
LOG_GENERATION_SUMMARY=false
LOG_PLANNING_INTEL=false
LOG_RETRY_TRACE=false
LOG_STRUCTURED_LLM_OUTPUT=false
