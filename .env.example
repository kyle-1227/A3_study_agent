# LLM settings
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# SiliconFlow (embedding, reranker, supervisor, fallback)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# RAG settings
CHROMA_PERSIST_DIR=chroma_store/
EMBEDDING_MODEL=BAAI/bge-m3

# Reranker (used by hybrid RAG pipeline)
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Fallback LLM (cross-provider failover via SiliconFlow)
FALLBACK_MODEL=Qwen/Qwen2.5-7B-Instruct
FALLBACK_API_KEY=your_siliconflow_api_key_here
FALLBACK_BASE_URL=https://api.siliconflow.cn/v1

# PostgreSQL settings (used by langgraph-checkpoint-postgres via psycopg)
DB_URI=postgresql://postgres:your_password@localhost:5432/gaokao_tutor

# CORS (comma-separated origins, default: http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000

# OpenTelemetry settings
OTEL_SERVICE_NAME=gaokao-tutor
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACING_ENABLED=true
OTEL_SQLITE_FALLBACK_PATH=logs/traces.db