# ── LLM API Keys ──────────────────────────────────────────
# DeepSeek (primary / fallback LLM)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# OpenRouter (structured LLM nodes, reranker, embedding)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=A3 Study Agent

# ── RAG ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=chroma_store/
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_API_KEY_ENV=OPENROUTER_API_KEY
EMBEDDING_DOCUMENT_INPUT_TYPE=passage
EMBEDDING_QUERY_INPUT_TYPE=query
EMBEDDING_TIMEOUT=60
RERANKER_MODEL=nvidia/llama-nemotron-rerank-vl-1b-v2:free
RERANKER_BASE_URL=https://openrouter.ai/api/v1
RERANKER_API_KEY_ENV=OPENROUTER_API_KEY
INDEX_ADD_BATCH_SIZE=64
INDEX_MAX_RETRIES=3

# ── Fallback LLM ──────────────────────────────────────────
# Uses DeepSeek as fallback when OpenRouter is unavailable.
# Typically reuses the same DEEPSEEK_API_KEY above.
FALLBACK_MODEL=deepseek-v4-flash
FALLBACK_API_KEY=your_deepseek_api_key_here
FALLBACK_BASE_URL=https://api.deepseek.com

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_PASSWORD=a3_study_dev

# LangGraph checkpointer
CHECKPOINTER_ENABLED=true
CHECKPOINTER_TYPE=postgres
DB_URI=postgresql://a3_user:a3_study_dev@localhost:5432/a3_study_agent

# ── CORS & Frontend ───────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Web Search
TAVILY_API_KEY=tvly-YOUR_API_KEY
WEB_SEARCH_PROVIDER=tavily

# ── Observability ─────────────────────────────────────────
OTEL_SERVICE_NAME=a3-study-agent
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACING_ENABLED=true
OTEL_SQLITE_FALLBACK_PATH=logs/traces.sqlite3

# ── Development diagnostics (A3_TRACE) ────────────────────
# Master switch — set to true to enable fine-grained switches below
LOG_A3_TRACE=false

LOG_SUPERVISOR_RESULT=false
LOG_QUERY_REWRITE_RESULT=false
LOG_RETRIEVAL_PLAN=false
LOG_RAG_RESULT=false
LOG_CONTEXT_ASSEMBLY=false
LOG_WEB_SEARCH_RESULT=false
LOG_GENERATION_SUMMARY=false
LOG_PLANNING_INTEL=false
LOG_RETRY_TRACE=false
LOG_STRUCTURED_LLM_OUTPUT=false
